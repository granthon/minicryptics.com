{{/* content/puzzle/_content.gotmpl
     Generates one Hugo page per puzzle from data/puzzles.yaml.
     The manifest is kept up to date by update_puzzles.py.
*/}}

{{ range hugo.Data.puzzles }}
  {{ $.AddPage (dict
    "kind"   "page"
    "type"   "puzzle"
    "path"   (lower .id)
    "title"  .title
    "date"   (time.AsTime .date)
    "params" (dict "puzzleid" .id)
    "description" (printf "%s — a mini cryptic crossword. Free to solve online." .title)
  ) }}
{{ end }}
